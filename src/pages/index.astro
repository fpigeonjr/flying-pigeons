---
const bandmates = [
  { name: "Abbie", role: "Vocals", variant: "vocal", accessory: "mic" },
  { name: "Carlos", role: "Guitars and Vocals", variant: "guitar", accessory: "pick" },
  { name: "Caleb", role: "Drums", variant: "drums", accessory: "sticks" },
  { name: "Frank", role: "Bass", variant: "bass", accessory: "bolt" },
  { name: "Paul", role: "Vocals", variant: "vocal-alt", accessory: "star" },
  { name: "DJ Elder", role: "MC and DJ", variant: "dj", accessory: "phones" },
];

const shows = [
  { date: "Summer 2025", venue: "First Flying Pigeons show", city: "Texas" },
  { date: "Soon", venue: "Texas dates loading", city: "Austin / San Antonio / Dallas" },
  { date: "Soon", venue: "Backyard punk night", city: "Central Texas" },
  { date: "Soon", venue: "Warehouse flyers incoming", city: "Follow for drops" },
];
---

<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta
      name="description"
      content="The Flying Pigeons: Texas punk, feathered and fearless."
    />
    <title>The Flying Pigeons</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Anton&family=Oswald:wght@500;700&display=swap"
      rel="stylesheet"
    />
    <style>
      :root {
        --ink: #0d0c09;
        --paper: #ead7af;
        --paper-dark: #d9bb85;
        --cream: #f5e7c6;
        --rust: #d74b1f;
        --rust-dark: #9e2c14;
        --teal: #184f46;
        --sage: #789078;
        --line: rgba(245, 231, 198, 0.22);
      }

      * {
        box-sizing: border-box;
      }

      html {
        background: var(--ink);
        scroll-behavior: smooth;
      }

      body {
        margin: 0;
        color: var(--cream);
        font-family: "Oswald", system-ui, sans-serif;
        background:
          radial-gradient(circle at 24% 18%, rgba(215, 75, 31, 0.18), transparent 22rem),
          linear-gradient(90deg, rgba(255,255,255,0.03) 1px, transparent 1px),
          linear-gradient(0deg, rgba(255,255,255,0.025) 1px, transparent 1px),
          var(--ink);
        background-size: auto, 34px 34px, 34px 34px, auto;
        letter-spacing: 0;
      }

      body::before {
        content: "";
        position: fixed;
        inset: 0;
        z-index: -1;
        pointer-events: none;
        opacity: 0.34;
        background-image:
          radial-gradient(circle, rgba(245,231,198,0.42) 0 1px, transparent 1px),
          radial-gradient(circle, rgba(0,0,0,0.7) 0 1px, transparent 1px);
        background-position: 0 0, 13px 17px;
        background-size: 19px 23px, 29px 31px;
        mix-blend-mode: overlay;
      }

      a {
        color: inherit;
        text-decoration: none;
      }

      .site-header {
        align-items: center;
        display: flex;
        gap: 2rem;
        justify-content: space-between;
        margin: 0 auto;
        max-width: 1220px;
        padding: 1.35rem clamp(1rem, 4vw, 3rem);
        position: relative;
        z-index: 2;
      }

      .brand {
        color: var(--cream);
        display: grid;
        font-family: "Anton", Impact, sans-serif;
        font-size: clamp(1.5rem, 3vw, 2.6rem);
        line-height: 0.84;
        text-transform: uppercase;
      }

      .brand span:first-child {
        color: var(--rust);
        font-family: "Oswald", sans-serif;
        font-size: 0.34em;
        letter-spacing: 0.08em;
      }

      .nav {
        display: flex;
        flex-wrap: wrap;
        gap: clamp(0.85rem, 2.3vw, 2rem);
        justify-content: flex-end;
        text-transform: uppercase;
      }

      .nav a {
        color: var(--paper);
        font-size: 0.88rem;
        font-weight: 700;
      }

      .nav a:hover,
      .nav a:focus-visible {
        color: var(--rust);
      }

      .hero {
        min-height: 760px;
        overflow: hidden;
        position: relative;
      }

      .hero::after,
      .black-band::before,
      .paper-band::before {
        background:
          linear-gradient(90deg, transparent, rgba(0,0,0,0.9) 12%, rgba(0,0,0,0.9) 88%, transparent),
          repeating-linear-gradient(90deg, transparent 0 13px, rgba(245,231,198,0.45) 13px 15px, transparent 15px 28px);
        bottom: -1px;
        content: "";
        height: 18px;
        left: 0;
        position: absolute;
        right: 0;
        z-index: 3;
      }

      .hero-inner {
        display: grid;
        gap: 2rem;
        grid-template-columns: minmax(0, 0.95fr) minmax(320px, 1.05fr);
        margin: 0 auto;
        max-width: 1220px;
        padding: clamp(2rem, 5vw, 5rem) clamp(1rem, 4vw, 3rem) 5rem;
        position: relative;
        z-index: 1;
      }

      .hero-copy {
        align-self: center;
      }

      .eyebrow {
        align-items: center;
        color: var(--rust);
        display: flex;
        font-weight: 700;
        gap: 0.65rem;
        margin: 0 0 1rem;
        text-transform: uppercase;
      }

      .star {
        color: var(--rust);
        font-family: "Anton", Impact, sans-serif;
      }

      h1,
      h2,
      h3 {
        font-family: "Anton", Impact, sans-serif;
        font-weight: 400;
        margin: 0;
        text-transform: uppercase;
      }

      h1 {
        color: var(--cream);
        font-size: clamp(4.2rem, 10.4vw, 9.4rem);
        line-height: 0.92;
        max-width: 760px;
        text-shadow: 2px 2px 0 #000;
      }

      .tagline {
        color: var(--rust);
        font-family: "Anton", Impact, sans-serif;
        font-size: clamp(1.25rem, 3vw, 2.25rem);
        margin: 1.6rem 0 2.2rem;
        text-transform: uppercase;
      }

      .button-row {
        display: flex;
        flex-wrap: wrap;
        gap: 1rem;
      }

      .button {
        align-items: center;
        background: var(--rust);
        border: 2px solid var(--rust);
        color: #120b08;
        display: inline-flex;
        font-family: "Anton", Impact, sans-serif;
        font-size: 1.05rem;
        justify-content: center;
        min-height: 54px;
        padding: 0.85rem 1.7rem;
        text-transform: uppercase;
      }

      .button.secondary {
        background: transparent;
        color: var(--paper);
      }

      .paper-band .button.secondary {
        border-color: var(--rust);
        color: var(--ink);
      }

      .button:hover,
      .button:focus-visible {
        transform: translate(-2px, -2px);
        box-shadow: 5px 5px 0 #000;
      }

      .poster-art {
        align-self: end;
        filter: drop-shadow(12px 14px 0 rgba(0, 0, 0, 0.35));
        justify-self: end;
        max-width: 700px;
        position: relative;
        width: min(100%, 700px);
      }

      .poster-art img {
        display: block;
        height: auto;
        transform: translateX(2%);
        width: 100%;
      }

      .sun {
        background:
          radial-gradient(circle, rgba(0,0,0,0.25) 0 1px, transparent 1px),
          var(--rust);
        background-size: 12px 12px, auto;
        border-radius: 50%;
        inset: 5% 1% 3% 6%;
        position: absolute;
        box-shadow: 0 0 0 5px rgba(13, 12, 9, 0.85), 0 0 0 8px var(--rust-dark);
      }

      .texas {
        color: var(--ink);
        font-family: "Anton", Impact, sans-serif;
        font-size: clamp(6rem, 17vw, 13rem);
        left: 6%;
        line-height: 1;
        opacity: 0.92;
        position: absolute;
        top: 22%;
        transform: rotate(-7deg);
      }

      .pigeon {
        bottom: 0;
        left: 27%;
        position: absolute;
        right: 0;
        top: 2%;
      }

      .crest {
        background: var(--teal);
        clip-path: polygon(50% 0, 58% 32%, 80% 8%, 72% 44%, 100% 28%, 76% 56%, 100% 63%, 66% 68%, 74% 100%, 50% 73%, 27% 100%, 34% 68%, 0 63%, 25% 56%, 0 28%, 28% 44%, 20% 8%, 42% 32%);
        height: 36%;
        left: 29%;
        position: absolute;
        top: 2%;
        transform: rotate(11deg);
        width: 42%;
      }

      .head {
        background: var(--sage);
        border: 7px solid var(--ink);
        border-radius: 48% 52% 42% 58%;
        height: 38%;
        left: 19%;
        position: absolute;
        top: 22%;
        transform: rotate(-15deg);
        width: 40%;
      }

      .eye {
        background: var(--rust);
        border: 6px solid var(--ink);
        border-radius: 50%;
        height: 42px;
        position: absolute;
        right: 20%;
        top: 29%;
        width: 42px;
      }

      .eye::after {
        background: #070604;
        border-radius: 50%;
        content: "";
        inset: 10px;
        position: absolute;
      }

      .beak {
        background: #c6ab73;
        clip-path: polygon(0 20%, 100% 50%, 0 80%);
        height: 15%;
        left: 6%;
        position: absolute;
        top: 41%;
        transform: rotate(-12deg);
        width: 25%;
      }

      .jacket {
        background: #111815;
        border: 7px solid var(--ink);
        border-radius: 48% 20% 0 0;
        bottom: 0;
        height: 55%;
        left: 24%;
        position: absolute;
        transform: skewX(-5deg);
        width: 62%;
      }

      .jacket::before,
      .jacket::after {
        background: var(--paper);
        content: "";
        height: 92%;
        position: absolute;
        top: 9%;
        width: 6px;
      }

      .jacket::before {
        left: 25%;
        transform: rotate(-17deg);
      }

      .jacket::after {
        right: 30%;
        transform: rotate(13deg);
      }

      .note {
        color: #070604;
        font-family: "Anton", Impact, sans-serif;
        font-size: clamp(3rem, 7vw, 5.4rem);
        position: absolute;
      }

      .note.one {
        right: 5%;
        top: 19%;
      }

      .note.two {
        left: 2%;
        top: 58%;
        transform: rotate(-16deg);
      }

      .paper-band,
      .black-band {
        position: relative;
      }

      .paper-band {
        background:
          radial-gradient(circle, rgba(13,12,9,0.18) 0 1px, transparent 1px),
          linear-gradient(90deg, rgba(255,255,255,0.18), transparent 30%, rgba(0,0,0,0.08)),
          var(--paper);
        background-size: 18px 18px, auto, auto;
        color: var(--ink);
      }

      .black-band {
        background:
          radial-gradient(circle, rgba(245,231,198,0.13) 0 1px, transparent 1px),
          var(--ink);
        background-size: 22px 22px, auto;
        color: var(--paper);
      }

      .section-inner {
        margin: 0 auto;
        max-width: 1220px;
        padding: clamp(3rem, 6vw, 5.5rem) clamp(1rem, 4vw, 3rem);
      }

      .section-title {
        align-items: center;
        display: flex;
        gap: 0.8rem;
        margin-bottom: 1.4rem;
      }

      .section-title h2 {
        font-size: clamp(2.2rem, 4.2vw, 4rem);
      }

      .video-grid {
        display: grid;
        gap: clamp(2rem, 5vw, 4rem);
        grid-template-columns: minmax(0, 1.16fr) minmax(280px, 0.84fr);
        align-items: center;
      }

      .video-wrapper {
        background: #090806;
        border: 5px solid var(--ink);
        box-shadow: 10px 10px 0 rgba(13, 12, 9, 0.22);
        position: relative;
      }

      .video-wrapper::before {
        content: "";
        display: block;
        padding-top: 56.25%;
      }

      .video-wrapper iframe {
        border: 0;
        height: 100%;
        inset: 0;
        position: absolute;
        width: 100%;
      }

      .big-statement {
        font-size: clamp(3.8rem, 8vw, 7rem);
        line-height: 0.94;
      }

      .copy {
        font-size: clamp(1rem, 1.5vw, 1.2rem);
        line-height: 1.55;
        margin: 1.35rem 0 1.7rem;
        max-width: 530px;
      }

      .shows-grid {
        display: grid;
        gap: 2rem;
        grid-template-columns: minmax(0, 1fr) minmax(280px, 360px);
      }

      .show-list {
        border-top: 1px solid rgba(245, 231, 198, 0.22);
      }

      .show-row {
        align-items: center;
        border-bottom: 1px solid rgba(245, 231, 198, 0.22);
        display: grid;
        gap: 1rem;
        grid-template-columns: 150px minmax(0, 1fr) minmax(0, 230px);
        padding: 1.1rem 0;
      }

      .show-date {
        color: var(--rust);
        font-family: "Anton", Impact, sans-serif;
        font-size: 1.7rem;
        text-transform: uppercase;
      }

      .show-venue {
        color: var(--cream);
        font-size: 1.2rem;
        font-weight: 700;
        text-transform: uppercase;
      }

      .show-city {
        color: var(--paper-dark);
      }

      .flyer {
        align-self: start;
        border: 5px solid var(--paper);
        color: var(--ink);
        min-height: 380px;
        padding: 1.2rem;
        position: relative;
        background:
          linear-gradient(180deg, transparent 0 48%, var(--rust) 48% 100%),
          var(--paper);
        box-shadow: 9px 9px 0 rgba(0, 0, 0, 0.45);
      }

      .flyer h3 {
        color: var(--ink);
        font-size: 3.6rem;
        line-height: 0.9;
      }

      .flyer-bird {
        bottom: 1.1rem;
        color: var(--ink);
        font-family: "Anton", Impact, sans-serif;
        font-size: 8rem;
        position: absolute;
        right: 1rem;
      }

      .flyer p {
        bottom: 1.5rem;
        color: var(--ink);
        font-family: "Anton", Impact, sans-serif;
        font-size: 1.6rem;
        line-height: 1;
        margin: 0;
        max-width: 180px;
        position: absolute;
        text-transform: uppercase;
      }

      .band-poster {
        background: #050403;
        border: 6px solid var(--ink);
        box-shadow: 12px 12px 0 rgba(13, 12, 9, 0.24);
        margin-top: 1.5rem;
        overflow: hidden;
        position: relative;
      }

      .band-poster::after {
        background:
          radial-gradient(circle, rgba(245,231,198,0.35) 0 1px, transparent 1px),
          linear-gradient(90deg, rgba(245,231,198,0.12), transparent 28%, rgba(215,75,31,0.08));
        background-size: 17px 17px, auto;
        content: "";
        inset: 0;
        mix-blend-mode: overlay;
        opacity: 0.28;
        pointer-events: none;
        position: absolute;
      }

      .band-poster img {
        display: block;
        height: auto;
        width: 100%;
      }

      .sr-only {
        border: 0;
        clip: rect(0 0 0 0);
        height: 1px;
        margin: -1px;
        overflow: hidden;
        padding: 0;
        position: absolute;
        white-space: nowrap;
        width: 1px;
      }

      .member-info {
        background: var(--rust);
        min-height: 88px;
        padding: 0.8rem 0.65rem;
        text-align: center;
      }

      .member h3 {
        color: #090604;
        font-size: 1.3rem;
        line-height: 1;
      }

      .member p {
        color: #090604;
        font-size: 0.86rem;
        font-weight: 700;
        margin: 0.35rem 0 0;
        text-transform: uppercase;
      }

      .footer {
        display: grid;
        gap: 2rem;
        grid-template-columns: 1fr auto 1fr;
        align-items: center;
      }

      .footer h2 {
        font-size: 2rem;
      }

      .email-form {
        display: flex;
        gap: 0.55rem;
        margin-top: 1rem;
      }

      .email-form input {
        background: transparent;
        border: 2px solid var(--paper);
        color: var(--paper);
        font: inherit;
        min-height: 42px;
        min-width: 0;
        padding: 0.55rem 0.75rem;
        width: 220px;
      }

      .email-form button {
        background: var(--rust);
        border: 2px solid var(--rust);
        color: #120b08;
        cursor: pointer;
        font-family: "Anton", Impact, sans-serif;
        padding: 0 1rem;
        text-transform: uppercase;
      }

      .badge {
        align-items: center;
        aspect-ratio: 1 / 1;
        border: 5px solid var(--paper);
        border-radius: 50%;
        display: flex;
        flex-direction: column;
        font-family: "Anton", Impact, sans-serif;
        justify-content: center;
        min-width: 180px;
        text-align: center;
        text-transform: uppercase;
      }

      .badge strong {
        color: var(--rust);
        font-size: 3.5rem;
        line-height: 0.85;
      }

      .socials {
        justify-self: end;
        text-align: right;
      }

      .social-links {
        display: flex;
        gap: 1rem;
        justify-content: flex-end;
        margin-top: 1rem;
      }

      .social-links a {
        align-items: center;
        border: 2px solid var(--paper);
        border-radius: 50%;
        display: inline-flex;
        font-family: "Anton", Impact, sans-serif;
        height: 48px;
        justify-content: center;
        width: 48px;
      }

      .copyright {
        color: var(--paper-dark);
        font-size: 0.9rem;
        grid-column: 1 / -1;
        text-align: center;
      }

      @media (max-width: 980px) {
        .hero-inner,
        .video-grid,
        .shows-grid,
        .footer {
          grid-template-columns: 1fr;
        }

        .poster-art {
          min-height: 460px;
          justify-self: center;
        }

        .socials {
          justify-self: start;
          text-align: left;
        }

        .social-links {
          justify-content: flex-start;
        }
      }

      @media (max-width: 680px) {
        .site-header {
          align-items: flex-start;
          flex-direction: column;
          gap: 1rem;
        }

        .nav {
          justify-content: flex-start;
        }

        .hero {
          min-height: auto;
        }

        .hero-inner {
          padding-top: 2rem;
        }

        .poster-art {
          min-height: 340px;
        }

        .show-row {
          grid-template-columns: 1fr;
          gap: 0.35rem;
        }

        .email-form {
          flex-direction: column;
          max-width: 320px;
        }

        .email-form input {
          width: 100%;
        }
      }
    </style>
  </head>
  <body>
    <main>
      <section class="hero" id="home">
        <header class="site-header">
          <a href="#home" class="brand" aria-label="The Flying Pigeons home">
            <span>The</span>
            <span>Flying</span>
            <span>Pigeons</span>
          </a>
          <nav class="nav" aria-label="Primary navigation">
            <a href="#shows">Shows</a>
            <a href="#music">Music</a>
            <a href="#videos">Videos</a>
            <a href="#band">Band</a>
            <a href="#contact">Contact</a>
          </nav>
        </header>

        <div class="hero-inner">
          <div class="hero-copy">
            <p class="eyebrow"><span class="star">★</span> Loud. Proud. Texas. <span class="star">★</span></p>
            <h1>Texas Punk. Feathered & Fearless.</h1>
            <p class="tagline">Live fast. Stay fly.</p>
            <div class="button-row">
              <a class="button" href="#videos">Watch Now</a>
              <a class="button secondary" href="#band">Meet the Band</a>
            </div>
          </div>

          <div class="poster-art" aria-label="Illustration of a punk pigeon in a leather jacket">
            <img
              src="/hero-pigeon-badge-transparent.png"
              alt="Circular The Flying Pigeons badge with a punk pigeon in a leather jacket, Texas silhouette, stars, and music notes."
              width="1254"
              height="1254"
            />
          </div>
        </div>
      </section>

      <section class="paper-band" id="videos">
        <div class="section-inner video-grid">
          <div>
            <div class="section-title">
              <span class="star">★</span>
              <h2>Featured Video</h2>
              <span class="star">★</span>
            </div>
            <div class="video-wrapper">
              <iframe
                src="https://www.youtube.com/embed/99xXLQd0mG4"
                title="The Flying Pigeons featured video"
                allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share"
                allowfullscreen
              ></iframe>
            </div>
          </div>
          <div id="music">
            <h2 class="big-statement">Live Fast. Stay Fly.</h2>
            <p class="copy">
              The Flying Pigeons bring a ruckus with fast songs, loud guitars,
              voices up front, and a whole lot of heart straight outta Texas.
            </p>
            <a class="button secondary" href="https://youtu.be/99xXLQd0mG4?si=kXIr_Y-myJFeXKPa" target="_blank" rel="noreferrer">
              Watch on YouTube
            </a>
          </div>
        </div>
      </section>

      <section class="black-band" id="shows">
        <div class="section-inner shows-grid">
          <div>
            <div class="section-title">
              <span class="star">★</span>
              <h2>Shows</h2>
              <span class="star">★</span>
            </div>
            <div class="show-list">
              {shows.map((show) => (
                <div class="show-row">
                  <div class="show-date">{show.date}</div>
                  <div class="show-venue">{show.venue}</div>
                  <div class="show-city">{show.city}</div>
                </div>
              ))}
            </div>
          </div>

          <aside class="flyer" aria-label="Live music flyer">
            <h3>Live Music Flying Pigeons</h3>
            <p>Bring your lawn chairs and hang out in our yard</p>
            <div class="flyer-bird">FP</div>
          </aside>
        </div>
      </section>

      <section class="paper-band" id="band">
        <div class="section-inner">
          <div class="section-title">
            <span class="star">★</span>
            <h2>The Band</h2>
            <span class="star">★</span>
          </div>
          <div class="band-poster">
            <img
              src="/band-pigeon-lineup.png"
              alt="The Flying Pigeons band lineup: Abbie on vocals, Carlos on guitars and vocals, Caleb on drums, Frank on bass, Paul on vocals, and DJ Elder as MC and DJ."
              width="1536"
              height="1024"
              loading="lazy"
            />
            <ul class="sr-only">
              {bandmates.map((member) => (
                <li>{member.name}: {member.role}</li>
              ))}
            </ul>
          </div>
        </div>
      </section>

      <footer class="black-band" id="contact">
        <div class="section-inner footer">
          <div>
            <h2>Stay in the Loop</h2>
            <p>Get show updates, new music, and other pigeon news.</p>
            <form class="email-form">
              <input type="email" placeholder="Your email address" aria-label="Email address" />
              <button type="submit">Subscribe</button>
            </form>

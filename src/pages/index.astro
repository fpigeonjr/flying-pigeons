---
import '../styles/global.css';

const bandmates = [
  { name: "Abbie", role: "Vocals", variant: "vocal", accessory: "mic" },
  { name: "Carlos", role: "Guitars and Vocals", variant: "guitar", accessory: "pick" },
  { name: "Caleb", role: "Drums", variant: "drums", accessory: "sticks" },
  { name: "Frank", role: "Bass", variant: "bass", accessory: "bolt" },
  { name: "Paul", role: "Vocals", variant: "vocal-alt", accessory: "star" },
  { name: "DJ Elder", role: "MC and DJ", variant: "dj", accessory: "phones" },
];

const shows = [
  { date: "Summer 2025", venue: "First Flying Pigeons show", city: "Texas" },
  { date: "Soon", venue: "Texas dates loading", city: "Austin / San Antonio / Dallas" },
  { date: "Soon", venue: "Backyard punk night", city: "Central Texas" },
  { date: "Soon", venue: "Warehouse flyers incoming", city: "Follow for drops" },
];
---

<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta
      name="description"
      content="The Flying Pigeons: Texas punk, feathered and fearless."
    />
    <title>The Flying Pigeons</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Anton&family=Oswald:wght@500;700&display=swap"
      rel="stylesheet"
    />
  </head>
  <body>
    <main>
      <section class="hero" id="home">
        <header class="site-header">
          <a href="#home" class="brand" aria-label="The Flying Pigeons home">
            <span>The</span>
            <span>Flying</span>
            <span>Pigeons</span>
          </a>
          <nav class="nav" aria-label="Primary navigation">
            <a href="#shows">Shows</a>
            <a href="#music">Music</a>
            <a href="#videos">Videos</a>
            <a href="#band">Band</a>
            <a href="#contact">Contact</a>
          </nav>
        </header>

        <div class="hero-inner">
          <div class="hero-copy">
            <p class="eyebrow"><span class="star">★</span> Loud. Proud. Texas. <span class="star">★</span></p>
            <h1>Texas Punk. Feathered & Fearless.</h1>
            <p class="tagline">Live fast. Stay fly.</p>
            <div class="button-row">
              <a class="btn" href="#videos">Watch Now</a>
              <a class="btn btn-secondary" href="#band">Meet the Band</a>
            </div>
          </div>

          <div class="poster-art" aria-label="Illustration of a punk pigeon in a leather jacket">
            <img
              src="/hero-pigeon-badge-transparent.png"
              alt="Circular The Flying Pigeons badge with a punk pigeon in a leather jacket, Texas silhouette, stars, and music notes."
              width="1254"
              height="1254"
            />
          </div>
        </div>
      </section>

      <section id="videos">
        <div class="section-inner video-grid">
          <div>
            <div class="section-title">
              <span class="star">★</span>
              <h2>Featured Video</h2>
              <span class="star">★</span>
            </div>
            <div class="video-wrapper">
              <iframe
                src="https://www.youtube.com/embed/99xXLQd0mG4"
                title="The Flying Pigeons featured video"
                allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share"
                allowfullscreen
              ></iframe>
            </div>
          </div>
          <div id="music">
            <h2 class="big-statement">Live Fast. Stay Fly.</h2>
            <p class="copy">
              The Flying Pigeons bring a ruckus with fast songs, loud guitars,
              voices up front, and a whole lot of heart straight outta Texas.
            </p>
            <a class="btn btn-secondary" href="https://youtu.be/99xXLQd0mG4?si=kXIr_Y-myJFeXKPa" target="_blank" rel="noreferrer">
              Watch on YouTube
            </a>
          </div>
        </div>
      </section>

      <section class="black-band" id="shows">
        <div class="section-inner shows-grid">
          <div>
            <div class="section-title">
              <span class="star">★</span>
              <h2>Shows</h2>
              <span class="star">★</span>
            </div>
            <div class="show-list">
              {shows.map((show) => (
                <div class="show-row">
                  <div class="show-date">{show.date}</div>
                  <div class="show-venue">{show.venue}</div>
                  <div class="show-city">{show.city}</div>
                </div>
              ))}
            </div>
          </div>

          <aside class="flyer" aria-label="Live music flyer">
            <h3>Live Music Flying Pigeons</h3>
            <p>Bring your lawn chairs and hang out in our yard</p>
            <div class="flyer-bird">FP</div>
          </aside>
        </div>
      </section>

      <section class="paper-band" id="band">
        <div class="section-inner">
          <div class="section-title">
            <span class="star">★</span>
            <h2>The Band</h2>
            <span class="star">★</span>
          </div>
          <div class="band-poster">
            <img
              src="/band-pigeon-lineup.png"
              alt="The Flying Pigeons band lineup: Abbie on vocals, Carlos on guitars and vocals, Caleb on drums, Frank on bass, Paul on vocals, and DJ Elder as MC and DJ."
              width="1536"
              height="1024"
              loading="lazy"
            />
            <ul class="sr-only">
              {bandmates.map((member) => (
                <li>{member.name}: {member.role}</li>
              ))}
            </ul>
          </div>
        </div>
      </section>

      <footer class="black-band" id="contact">
        <div class="section-inner footer">
          <div>
            <h2>Stay in the Loop</h2>
            <p>Get show updates, new music, and other pigeon news.</p>
            <form class="email-form">
              <input type="email" placeholder="Your email address" aria-label="Email address" />
              <button type="submit">Subscribe</button>
            </form>
          </div>

          <div class="badge" aria-label="Texas punk feathered and fearless badge">
            <span>Texas Punk</span>
            <strong>FP</strong>
            <span>Feathered & Fearless</span>
          </div>

          <div class="socials">
            <h2>Follow the Flock</h2>
            <div class="social-links">
              <a
                href="https://www.youtube.com/@TheFlyingPigeons"
                target="_blank"
                rel="noreferrer"
                aria-label="YouTube"
              >YT</a>
              <a
                href="https://x.com/theflypigeons"
                target="_blank"
                rel="noreferrer"
                aria-label="X"
              >X</a>
            </div>
          </div>

          <p class="copyright">© 2026 The Flying Pigeons. All rights reserved.</p>
        </div>
      </footer>
    </main>
  </body>
</html>